# Server Configuration
PORT=3000
NODE_ENV=development

# CORS allowed origins — comma-separated list
# capacitor://localhost = Android app (production)
# http://localhost:5173 = local web dev
FRONTEND_URL=http://localhost:5173,capacitor://localhost

# Backend's own public URL — used for UddoktaPay redirect/cancel URLs
# In dev: http://localhost:3000
# In production (Render): https://uddoktapay-backend.onrender.com
BACKEND_URL=http://localhost:3000

# Webhook URL = same as BACKEND_URL (Render deployment)
WEBHOOK_URL=https://uddoktapay-backend.onrender.com

# Frontend (Vite) should set:
# VITE_BACKEND_URL=http://localhost:3000         (local dev)
# VITE_BACKEND_URL=https://uddoktapay-backend.onrender.com  (production Android build)
